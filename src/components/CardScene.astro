---
import type { RecordModel } from "pocketbase";
import iconUserMulti from "../assets/icons/user_multi.svg";

interface Props {
    scene: RecordModel;
}

const { scene } = Astro.props;

const pbUrl = "http://127.0.0.1:8090";
const imgUrl =
    scene.photo && scene.photo.length > 0
        ? `${pbUrl}/api/files/${scene.collectionId}/${scene.id}/${scene.photo[0]}`
        : "";

const equipementsParScene: Record<string, string[]> = {
    "Main Stage": [
        "Système L-Acoustics K1",
        "Écrans LED 4K",
        "120 lasers RGB",
        "Show de drones",
    ],
    "Reflets Stage": [
        "Effets aquatiques",
        "Mapping vidéo",
        "Hologrammes",
        "Acteurs vivants",
    ],
    "Drones Stage": [
        "300 drones LED",
        "Effets 3D",
        "Interaction artistique",
        "Expérience immersive",
    ],
};
const equipements = equipementsParScene[scene.nom] || [];
---

<div
    class="bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform"
>
    <div class="relative">
        {
            imgUrl ? (
                <img
                    src={imgUrl}
                    alt={scene.nom}
                    class="w-full h-64 object-cover"
                />
            ) : (
                <div class="w-full h-64 bg-violet-foncer flex items-center justify-center">
                    <span class="text-gris">Pas d'image</span>
                </div>
            )
        }
    </div>

    <div class="p-6">
        <h3
            class="text-2xl font-bold mb-3 bg-gradient-3c bg-clip-text text-transparent"
        >
            {scene.nom}
        </h3>
        <p class="text-gris text-sm mb-4">{scene.description}</p>

        <div class="flex items-center gap-2 mb-4">
            <img src={iconUserMulti.src} alt="Capacité" class="w-5 h-5" />
            <span class="text-white text-sm font-medium"
                >{scene.capacite} personnes</span
            >
        </div>

        {
            equipements.length > 0 && (
                <div class="flex flex-wrap gap-2 mb-4">
                    {equipements.slice(0, 4).map((equipement) => (
                        <span class="bg-violet-foncer text-gris text-xs px-3 py-1 rounded-full">
                            {equipement}
                        </span>
                    ))}
                </div>
            )
        }

        <a
            href={`/scene/${scene.id}`}
            class="inline-flex items-center gap-2 text-violet hover:text-white text-sm font-medium transition-colors"
        >
            Plus de détails
            <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="2"
                stroke="currentColor"
                class="w-4 h-4"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
            </svg>
        </a>
    </div>
</div>
