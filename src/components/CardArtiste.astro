---
import type { RecordModel } from "pocketbase";

interface Props {
    artiste: RecordModel;
    scenes: RecordModel[];
}

const { artiste, scenes } = Astro.props;

const pbUrl = "http://127.0.0.1:8090";
const imgUrl = artiste.photo_principale
    ? `${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`
    : "";

const sceneMatch = scenes.find((s) => s.id === artiste.scene);
const sceneName = sceneMatch ? sceneMatch.nom : "Scène inconnue";

const dateObj = new Date(artiste.date_representation);
const dateStr = dateObj.toLocaleDateString("fr-FR", {
    weekday: "long",
    day: "numeric",
    month: "long",
});
const timeStr = dateObj.toLocaleTimeString("fr-FR", {
    hour: "2-digit",
    minute: "2-digit",
});
---

<a
    href={`/artiste/${artiste.id}`}
    class="bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform block"
>
    <div class="relative">
        {
            imgUrl ? (
                <img
                    src={imgUrl}
                    alt={artiste.nom}
                    class="w-full h-48 object-cover"
                />
            ) : (
                <div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
                    <span class="text-gris">Pas d'image</span>
                </div>
            )
        }
        <span
            class="absolute top-3 left-3 bg-violet text-white text-xs px-3 py-1 rounded-full"
        >
            {artiste.genre_musical}
        </span>
    </div>

    <div class="p-4">
        <h3 class="text-white text-xl font-bold mb-2">{artiste.nom}</h3>
        <p class="text-gris text-sm mb-1 capitalize">{dateStr}</p>
        <p class="text-violet text-sm font-medium">{sceneName}</p>
        <p class="text-gris text-sm">{timeStr}</p>
    </div>
</a>
