---
import Layout from '../layouts/Layout.astro';
import { scenesName, allartistebysceneId } from '../../backend/backend.mjs';

// Icone
import iconUserMulti from '../assets/icons/user_multi.svg';

// Recuperer les scenes depuis PocketBase
let scenes = [];

try {
	scenes = await scenesName();
} catch (error) {
	console.error("Erreur lors de la recuperation des scenes:", error);
}

// URL de base PocketBase pour les images
const pbUrl = "http://127.0.0.1:8090";
---

<Layout title="Les Scenes - Lumimix">
	
	<!-- HEADER DE PAGE -->
	<section class="pt-32 pb-16 px-4 text-center">
		<h1 class="text-white text-5xl font-bold mb-4">Les Scenes</h1>
		<p class="text-gris text-lg max-w-2xl mx-auto">
			{scenes.length} scenes uniques pour une experience immersive totale
		</p>
	</section>

	<!-- LISTE DES SCENES -->
	<section class="pb-16 px-4">
		<div class="max-w-5xl mx-auto flex flex-col gap-12">
			
			{scenes.map((scene) => (
				<!-- CARTE SCENE -->
				<div class="bg-violet-foncer/30 rounded-2xl overflow-hidden">
					
					<!-- Image -->
					{scene.image ? (
						<img 
							src={`${pbUrl}/api/files/${scene.collectionId}/${scene.id}/${scene.image}`}
							alt={scene.nom} 
							class="w-full h-64 md:h-80 object-cover"
						/>
					) : (
						<div class="w-full h-64 md:h-80 bg-violet-foncer flex items-center justify-center">
							<span class="text-gris text-xl">Pas d'image</span>
						</div>
					)}
					
					<!-- Contenu -->
					<div class="p-6 md:p-8">
						
						<!-- Titre et capacite -->
						<div class="flex flex-wrap items-center justify-between gap-4 mb-4">
							<h2 class="text-white text-3xl font-bold">{scene.nom}</h2>
							{scene.capacite && (
								<div class="flex items-center gap-2 text-violet">
									<img src={iconUserMulti.src} alt="" class="w-5 h-5"/>
									<span class="font-medium">{scene.capacite} personnes</span>
								</div>
							)}
						</div>
						
						<!-- Description -->
						{scene.description && (
							<p class="text-gris mb-6">{scene.description}</p>
						)}
						
						<!-- Bouton voir les artistes -->
						<a 
							href={`/artiste`}
							class="inline-block bg-violet text-white px-6 py-2 rounded-full font-bold hover:opacity-80"
						>
							Voir les artistes
						</a>
						
					</div>
				</div>
			))}

		</div>
	</section>

	<!-- MESSAGE SI PAS DE SCENES -->
	{scenes.length === 0 && (
		<section class="pb-16 text-center">
			<p class="text-gris text-lg">Aucune scene trouvee. Verifiez que PocketBase est lance.</p>
		</section>
	)}

	<!-- BOUTON RETOUR -->
	<section class="pb-16 text-center">
		<a 
			href="/" 
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
		>
			Retour a l'accueil
		</a>
	</section>

</Layout>
