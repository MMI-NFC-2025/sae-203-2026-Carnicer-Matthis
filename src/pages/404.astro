---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - Page introuvable | LumiMix">
    <section
        class="flex flex-col items-center justify-center min-h-[70vh] text-center px-6"
    >
        <h1 class="text-9xl font-extrabold text-purple-500">404</h1>
        <p class="mt-4 text-2xl font-semibold text-white md:text-3xl">
            Page introuvable
        </p>
        <p class="mt-2 text-gray-400">
            La page que vous recherchez n'existe pas ou a été déplacée.
        </p>
        <a
            href="/"
            class="mt-8 inline-block rounded-lg bg-purple-600 px-6 py-3 text-white font-medium transition hover:bg-purple-700"
        >
            Retour à l'accueil
        </a>
    </section>
</Layout>
