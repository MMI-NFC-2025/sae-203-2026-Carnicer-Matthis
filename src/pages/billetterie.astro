---
import Layout from '../layouts/Layout.astro';

// Icones
import iconTicket from '../assets/icons/ticket.svg';
import iconCalendrier from '../assets/icons/calendrier.svg';
import iconEtoile from '../assets/icons/etoile.svg';

// Liste des billets
const billets = [
	{
		nom: "Pass 1 Jour",
		prix: "49",
		description: "Acces a une soiree du festival",
		avantages: [
			"Acces a toutes les scenes",
			"1 soiree au choix",
			"Zone restauration"
		],
		populaire: false
	},
	{
		nom: "Pass 3 Jours",
		prix: "119",
		description: "L'experience complete du festival",
		avantages: [
			"Acces a toutes les scenes",
			"3 soirees completes",
			"Zone restauration",
			"Parking inclus"
		],
		populaire: true
	},
	{
		nom: "Pass VIP",
		prix: "249",
		description: "Une experience premium exclusive",
		avantages: [
			"Acces a toutes les scenes",
			"3 soirees completes",
			"Zone VIP exclusive",
			"Open bar",
			"Parking VIP",
			"Meet & Greet artistes"
		],
		populaire: false
	}
];
---

<Layout title="Billetterie - Lumimix">
	
	<!-- HEADER DE PAGE -->
	<section class="pt-32 pb-16 px-4 text-center">
		<h1 class="text-white text-5xl font-bold mb-4">Billetterie</h1>
		<p class="text-gris text-lg max-w-2xl mx-auto">
			Reservez vos places pour vivre une experience unique
		</p>
	</section>

	<!-- CARTES BILLETS -->
	<section class="pb-16 px-4">
		<div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-6">
			
			{billets.map((billet) => (
				<!-- CARTE BILLET -->
				<div class={`relative rounded-2xl overflow-hidden p-6 ${billet.populaire ? 'bg-violet' : 'bg-violet-foncer/30'}`}>
					
					<!-- Badge populaire -->
					{billet.populaire && (
						<div class="absolute top-4 right-4 bg-white text-violet text-xs font-bold px-3 py-1 rounded-full">
							Populaire
						</div>
					)}
					
					<!-- Icone -->
					<img src={iconTicket.src} alt="" class="w-12 h-12 mb-4"/>
					
					<!-- Nom -->
					<h3 class="text-white text-2xl font-bold mb-2">{billet.nom}</h3>
					
					<!-- Prix -->
					<div class="mb-4">
						<span class="text-white text-4xl font-bold">{billet.prix}</span>
						<span class="text-white/70">EUR</span>
					</div>
					
					<!-- Description -->
					<p class={`mb-6 ${billet.populaire ? 'text-white/80' : 'text-gris'}`}>
						{billet.description}
					</p>
					
					<!-- Avantages -->
					<ul class="space-y-3 mb-8">
						{billet.avantages.map((avantage) => (
							<li class="flex items-center gap-2 text-white">
								<span class={`w-2 h-2 rounded-full ${billet.populaire ? 'bg-white' : 'bg-violet'}`}></span>
								{avantage}
							</li>
						))}
					</ul>
					
					<!-- Bouton -->
					<a 
						href="#" 
						class={`block text-center py-3 rounded-full font-bold ${billet.populaire ? 'bg-white text-violet hover:bg-white/90' : 'bg-violet text-white hover:opacity-80'}`}
					>
						Reserver
					</a>
					
				</div>
			))}

		</div>
	</section>

	<!-- INFOS IMPORTANTES -->
	<section class="pb-16 px-4">
		<div class="max-w-3xl mx-auto">
			<h2 class="text-white text-3xl font-bold text-center mb-8">Informations importantes</h2>
			
			<div class="bg-violet-foncer/30 rounded-2xl p-6 md:p-8">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
					
					<div class="flex gap-4">
						<img src={iconCalendrier.src} alt="" class="w-8 h-8"/>
						<div>
							<h4 class="text-white font-bold mb-1">Dates du festival</h4>
							<p class="text-gris text-sm">18, 19 et 20 Juillet 2025</p>
						</div>
					</div>
					
					<div class="flex gap-4">
						<img src={iconEtoile.src} alt="" class="w-8 h-8"/>
						<div>
							<h4 class="text-white font-bold mb-1">Billets non remboursables</h4>
							<p class="text-gris text-sm">Sauf annulation du festival</p>
						</div>
					</div>
					
				</div>
			</div>
		</div>
	</section>

	<!-- BOUTON RETOUR -->
	<section class="pb-16 text-center">
		<a 
			href="/" 
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
		>
			Retour a l'accueil
		</a>
	</section>

</Layout>
