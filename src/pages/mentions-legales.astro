---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mentions légales - Lumimix">
	
	<!-- HEADER DE PAGE -->
	<section class="pt-32 pb-16 px-4 text-center">
		<h1 class="text-white text-5xl font-bold mb-4">Mentions légales</h1>
	</section>

	<!-- CONTENU -->
	<section class="pb-16 px-4">
		<div class="max-w-3xl mx-auto space-y-8">
			
			<!-- Editeur -->
			<div class="bg-violet-foncer/30 rounded-2xl p-6">
				<h2 class="text-violet text-xl font-bold mb-4">Editeur du site</h2>
				<p class="text-gris">
					Lumimix Festival<br/>
					Association loi 1901<br/>
					Lac de Malsaucy<br/>
					90300 Sermamagny<br/>
					France
				</p>
			</div>

			<!-- Hebergeur -->
			<div class="bg-violet-foncer/30 rounded-2xl p-6">
				<h2 class="text-violet text-xl font-bold mb-4">Hebergement</h2>
				<p class="text-gris">
					Ce site est heberge par Vercel Inc.<br/>
					340 S Lemon Ave #4133<br/>
					Walnut, CA 91789<br/>
					USA
				</p>
			</div>

			<!-- Propriete intellectuelle -->
			<div class="bg-violet-foncer/30 rounded-2xl p-6">
				<h2 class="text-violet text-xl font-bold mb-4">Propriete intellectuelle</h2>
				<p class="text-gris">
					L'ensemble du contenu de ce site (textes, images, logos, videos) est la propriete exclusive de Lumimix Festival ou de ses partenaires. Toute reproduction, meme partielle, est interdite sans autorisation prealable.
				</p>
			</div>

			<!-- Donnees personnelles -->
			<div class="bg-violet-foncer/30 rounded-2xl p-6">
				<h2 class="text-violet text-xl font-bold mb-4">Protection des donnees</h2>
				<p class="text-gris">
					Conformement au RGPD, vous disposez d'un droit d'acces, de rectification et de suppression de vos donnees personnelles. Pour exercer ce droit, contactez-nous a l'adresse : contact@lumimix-festival.fr
				</p>
			</div>

		</div>
	</section>

	<!-- BOUTON RETOUR -->
	<section class="pb-16 text-center">
		<a 
			href="/" 
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
		>
			Retour a l'accueil
		</a>
	</section>

</Layout>
