---
import Layout from "../../layouts/Layout.astro";
import CardScene from "../../components/CardScene.astro";
import { scenesName } from "../../../backend/backend.mjs";
import type { RecordModel } from "pocketbase";
import sceneRougeFondImage from "../../assets/img/scene_rouge_fond.avif";

let scenes: RecordModel[] = [];
try {
	scenes = await scenesName();
} catch (error) {
	console.error("Erreur:", error);
}
---

<Layout title="Scènes - Lumimix">
	<section
		class="relative h-[70vh] flex items-start justify-center px-4 text-center pt-40"
	>
		<img
			src={sceneRougeFondImage.src}
			alt="Scene Background"
			class="absolute inset-0 w-full h-full object-cover z-0"
		/>
		<div class="absolute inset-0 bg-black/50 z-10"></div>
		<div class="relative z-20">
			<h1
				class="text-5xl font-bold mb-4 bg-gradient-3c bg-clip-text text-transparent"
			>
				Les Scènes
			</h1>
			<p class="text-white text-lg max-w-2xl mx-auto">
				{scenes.length} scènes uniques pour une expérience immersive totale
			</p>
		</div>
	</section>

	<section class="pt-16 pb-16 px-4">
		<div
			class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6"
		>
			{scenes.map((scene) => <CardScene scene={scene} />)}
		</div>
	</section>

	{
		scenes.length === 0 && (
			<section class="pb-16 text-center">
				<p class="text-gris text-lg">
					Aucune scène trouvée. Vérifiez que PocketBase est lancé.
				</p>
			</section>
		)
	}

	<section class="pb-16 text-center">
		<a
			href="/"
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white transition-colors"
		>
			Retour à l'accueil
		</a>
	</section>
</Layout>
