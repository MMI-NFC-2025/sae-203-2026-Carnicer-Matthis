---
import Layout from "../../layouts/Layout.astro";
import { sceneID, allartistebysceneId } from "../../../backend/backend.mjs";
import type { RecordModel } from "pocketbase";

const { id } = Astro.params;

let scene: RecordModel | null = null;
let artistes: RecordModel[] = [];
let error: string | null = null;

if (!id) {
	error = "ID manquant";
} else {
	try {
		scene = await sceneID(id);
		if (scene) {
			artistes = await allartistebysceneId(scene.id);
		}
	} catch (e) {
		error = "Scène non trouvée";
	}
}

const pbUrl = "http://127.0.0.1:8090";

function formatDate(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleDateString("fr-FR", {
		weekday: "long",
		day: "numeric",
		month: "long",
	});
}

function formatTime(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleTimeString("fr-FR", {
		hour: "2-digit",
		minute: "2-digit",
	});
}
---

<Layout title={scene ? `${scene.nom} - Lumimix` : "Scène - Lumimix"}>
	{
		error ? (
			<section class="pt-32 pb-16 px-4 text-center min-h-screen">
				<h1 class="text-white text-4xl font-bold mb-4">
					Scène non trouvée
				</h1>
				<p class="text-gris mb-8">
					La scène que vous recherchez n'existe pas ou l'URL est
					incorrecte.
				</p>
				<a
					href="/scene"
					class="inline-block bg-violet text-white px-8 py-3 rounded-full font-bold hover:opacity-80"
				>
					Voir toutes les scènes
				</a>
			</section>
		) : (
			scene && (
				<>
					<section class="pt-32 pb-16 px-4">
						<div class="max-w-5xl mx-auto">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
								<div class="relative">
									{scene.photo && scene.photo.length > 0 ? (
										<img
											src={`${pbUrl}/api/files/${scene.collectionId}/${scene.id}/${scene.photo[0]}`}
											alt={scene.nom}
											class="w-full h-96 object-cover rounded-2xl"
										/>
									) : (
										<div class="w-full h-96 bg-violet-foncer rounded-2xl flex items-center justify-center text-center">
											<div>
												<span class="text-gris text-xl block mb-2">
													📸
												</span>
												<span class="text-gris">
													Pas d'image disponible
												</span>
											</div>
										</div>
									)}
								</div>

								<div>
									<h1 class="text-5xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent">
										{scene.nom}
									</h1>
									<div class="space-y-4 mb-8">
										<div class="flex items-center gap-3">
											<span class="text-violet font-bold">
												Capacité :
											</span>
											<span class="text-white">
												{scene.capacite} personnes
											</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-violet font-bold">
												Artistes :
											</span>
											<span class="text-white">
												{artistes.length} artiste{artistes.length > 1 ? "s" : ""}
											</span>
										</div>
									</div>

									<div class="flex flex-wrap gap-4">
										<a
											href="/billetterie"
											class="bg-gradient-3c text-white px-8 py-3 rounded-full font-bold hover:opacity-80 transition-opacity"
										>
											Réserver ma place
										</a>
										<a
											href="/artiste"
											class="border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white transition-colors"
										>
											Voir les artistes
										</a>
									</div>
								</div>
							</div>
						</div>
					</section>

					{artistes.length > 0 && (
						<section class="pb-16 px-4">
							<div class="max-w-5xl mx-auto">
								<h2 class="text-3xl font-bold mb-8 bg-gradient-3c bg-clip-text text-transparent">
									Artistes programmés sur cette scène
								</h2>
								<div class="relative overflow-hidden group">
									<button
										id="prev-artistes"
										class="absolute left-2 top-1/2 -translate-y-1/2 z-10 bg-violet/80 text-white p-3 rounded-full hover:bg-violet transition-all opacity-0 group-hover:opacity-100"
										aria-label="Artiste précédent"
									>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
										</svg>
									</button>
									<button
										id="next-artistes"
										class="absolute right-2 top-1/2 -translate-y-1/2 z-10 bg-violet/80 text-white p-3 rounded-full hover:bg-violet transition-all opacity-0 group-hover:opacity-100"
										aria-label="Artiste suivant"
									>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
										</svg>
									</button>
									<div
										id="carousel-artistes"
										class="flex transition-transform duration-500 ease-in-out"
									>
										{artistes.map((artiste: RecordModel) => (
											<div class="min-w-full md:min-w-[33.333%] px-2">
												<a
													href={`/artiste/${artiste.id}`}
													class="block bg-violet-foncer rounded-xl overflow-hidden hover:transform hover:scale-105 transition-all"
												>
													{artiste.photo_principale ? (
														<img
															src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
															alt={artiste.nom}
															class="w-full h-48 object-cover"
														/>
													) : (
														<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
															<span class="text-gris">
																Pas d'image
															</span>
														</div>
													)}
													<div class="p-4">
														<h3 class="text-xl font-bold text-white mb-2">
															{artiste.nom}
														</h3>
														<p class="text-violet font-bold mb-2">
															{artiste.genre_musical}
														</p>
														<p class="text-gris text-sm">
															{formatDate(
																artiste.date_representation,
															)}{" "}
															à{" "}
															{formatTime(
																artiste.date_representation,
															)}
														</p>
													</div>
												</a>
											</div>
										))}
										{artistes.map((artiste: RecordModel) => (
											<div class="min-w-full md:min-w-[33.333%] px-2">
												<a
													href={`/artiste/${artiste.id}`}
													class="block bg-violet-foncer rounded-xl overflow-hidden hover:transform hover:scale-105 transition-all"
												>
													{artiste.photo_principale ? (
														<img
															src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
															alt={artiste.nom}
															class="w-full h-48 object-cover"
														/>
													) : (
														<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
															<span class="text-gris">
																Pas d'image
															</span>
														</div>
													)}
													<div class="p-4">
														<h3 class="text-xl font-bold text-white mb-2">
															{artiste.nom}
														</h3>
														<p class="text-violet font-bold mb-2">
															{artiste.genre_musical}
														</p>
														<p class="text-gris text-sm">
															{formatDate(
																artiste.date_representation,
															)}{" "}
															à{" "}
															{formatTime(
																artiste.date_representation,
															)}
														</p>
													</div>
												</a>
											</div>
										))}
									</div>
								</div>
							</div>
						</section>
					)}

					<script>
						const carouselArtistes = document.getElementById('carousel-artistes');
						const prevBtnArtistes = document.getElementById('prev-artistes');
						const nextBtnArtistes = document.getElementById('next-artistes');
						
						if (carouselArtistes && prevBtnArtistes && nextBtnArtistes) {
							const totalItems = carouselArtistes.children.length / 2;
							const itemsPerSlide = window.innerWidth >= 768 ? 3 : 1;
							let currentIndex = 0;
							
							function updateCarousel() {
								const itemWidth = 100 / itemsPerSlide;
								const offset = -(itemWidth * currentIndex);
								carouselArtistes!.style.transform = `translateX(${offset}%)`;
							}
							
							nextBtnArtistes.addEventListener('click', () => {
								currentIndex++;
								updateCarousel();
								
								if (currentIndex >= totalItems) {
									setTimeout(() => {
										carouselArtistes!.style.transition = 'none';
										currentIndex = 0;
										updateCarousel();
										setTimeout(() => {
											carouselArtistes!.style.transition = 'transform 500ms ease-in-out';
										}, 20);
									}, 500);
								}
							});
							
							prevBtnArtistes.addEventListener('click', () => {
								if (currentIndex === 0) {
									carouselArtistes!.style.transition = 'none';
									currentIndex = totalItems;
									updateCarousel();
									setTimeout(() => {
										carouselArtistes!.style.transition = 'transform 500ms ease-in-out';
										currentIndex--;
										updateCarousel();
									}, 20);
								} else {
									currentIndex--;
									updateCarousel();
								}
							});
						}
					</script>
				</>
			)
		)
	}
</Layout>
