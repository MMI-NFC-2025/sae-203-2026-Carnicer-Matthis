---
import Layout from "../layouts/Layout.astro";
import { artistesSorted, scenesName } from "../../backend/backend.mjs";
import type { RecordModel } from "pocketbase";
import heroImage from "../assets/img/scene_bleu_fond.avif";

let artistes: RecordModel[] = [];
let scenes: RecordModel[] = [];

try {
	artistes = await artistesSorted();
	scenes = await scenesName();
} catch (error) {
	console.log("[v0] Erreur PocketBase:", error);
}

const genresUniques = [...new Set(artistes.map((a) => a.genre_musical))].filter(
	Boolean,
);

const pbUrl = "https://lumimix.carnicer.fr:443";

function getImageUrl(record, field) {
	if (record && record[field]) {
		return `${pbUrl}/api/files/${record.collectionId}/${record.id}/${record[field]}`;
	}
	return heroImage.src;
}

const jour1 = artistes.filter((a) => {
	const date = new Date(a.date_representation);
	return date.getDate() === 18;
});
const jour2 = artistes.filter((a) => {
	const date = new Date(a.date_representation);
	return date.getDate() === 19;
});
const jour3 = artistes.filter((a) => {
	const date = new Date(a.date_representation);
	return date.getDate() === 20;
});

function formatHeure(dateStr) {
	const date = new Date(dateStr);
	return date.toLocaleTimeString("fr-FR", {
		hour: "2-digit",
		minute: "2-digit",
	});
}
---

<Layout title="Programme - Lumimix">
	<!-- HERO -->
	<section
		class="relative h-[70vh] flex items-center justify-center -mt-24 pt-32"
	>
		<img
			src={heroImage.src}
			alt="Festival Lumimix"
			class="absolute inset-0 w-full h-full object-cover"
		/>
		<div class="absolute inset-0 bg-black/60"></div>
		<div class="relative z-10 text-center px-4">
			<h1
				class="text-5xl md:text-6xl font-bold mb-4 bg-gradient-3c bg-clip-text text-transparent"
			>
				Programme
			</h1>
			<p class="text-white text-lg md:text-xl">
				3 nuits de musique électronique avec les meilleurs DJs
			</p>
		</div>
	</section>

	<!-- FILTRES -->
	<section class="py-8 px-4 border-b border-violet/20">
		<div class="max-w-5xl mx-auto">
			<h2 class="text-white font-bold text-xl mb-4">Filtrer par :</h2>

			<!-- Filtre par jour -->
			<div class="mb-6">
				<p class="text-gris text-sm mb-2">Jour</p>
				<div class="flex flex-wrap gap-2">
					<button
						data-filter-jour="tous"
						class="filter-btn-jour active px-4 py-2 rounded-full bg-violet text-white font-bold hover:opacity-80 transition-opacity"
					>
						Tous les jours
					</button>
					<button
						data-filter-jour="18"
						class="filter-btn-jour px-4 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
					>
						Vendredi 18
					</button>
					<button
						data-filter-jour="19"
						class="filter-btn-jour px-4 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
					>
						Samedi 19
					</button>
					<button
						data-filter-jour="20"
						class="filter-btn-jour px-4 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
					>
						Dimanche 20
					</button>
				</div>
			</div>

			<!-- Filtre par scène -->
			<div class="mb-6">
				<p class="text-gris text-sm mb-2">Scène</p>
				<div class="flex flex-wrap gap-2">
					<button
						data-filter-scene="toutes"
						class="filter-btn-scene active px-4 py-2 rounded-full bg-violet text-white font-bold hover:opacity-80 transition-opacity"
					>
						Toutes les scènes
					</button>
					{
						scenes.map((scene) => (
							<button
								data-filter-scene={scene.id}
								class="filter-btn-scene px-4 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
							>
								{scene.nom}
							</button>
						))
					}
				</div>
			</div>

			<!-- Filtre par genre -->
			<div class="mb-6">
				<p class="text-gris text-sm mb-2">Genre musical</p>
				<div class="flex flex-wrap gap-2">
					<button
						data-filter-genre="tous"
						class="filter-btn-genre active px-4 py-2 rounded-full bg-violet text-white font-bold hover:opacity-80 transition-opacity"
					>
						Tous les genres
					</button>
					{
						genresUniques.map((genre) => (
							<button
								data-filter-genre={genre}
								class="filter-btn-genre px-4 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
							>
								{genre}
							</button>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<!-- PROGRAMME PAR JOUR -->
	<section class="py-16 px-4">
		<div class="max-w-5xl mx-auto">
			<!-- JOUR 1 -->
			<div class="mb-16" data-section-jour="18">
				<h2 class="text-white text-3xl font-bold mb-8 text-center">
					<span class="text-violet">Vendredi</span> 18 Juillet
				</h2>

				{
					jour1.length > 0 ? (
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
							{jour1.map((artiste) => (
								<a
									href={`/artiste/${artiste.id}`}
									class="artiste-card bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform"
									data-jour="18"
									data-scene={artiste.scene || ""}
									data-genre={artiste.genre_musical || ""}
								>
									{artiste.photo_principale ? (
										<img
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
											alt={artiste.nom}
											class="w-full h-48 object-cover"
										/>
									) : (
										<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
											<span class="text-gris text-sm">
												Pas d'image
											</span>
										</div>
									)}
									<div class="p-4">
										<h3 class="text-white text-xl font-bold">
											{artiste.nom}
										</h3>
										<p class="text-violet">
											{formatHeure(
												artiste.date_representation,
											)}
										</p>
										<p class="text-gris text-sm">
											{artiste.genre_musical}
										</p>
									</div>
								</a>
							))}
						</div>
					) : (
						<p class="text-gris text-center">
							Programmation a venir...
						</p>
					)
				}
			</div>

			<!-- JOUR 2 -->
			<div class="mb-16" data-section-jour="19">
				<h2 class="text-white text-3xl font-bold mb-8 text-center">
					<span class="text-violet">Samedi</span> 19 Juillet
				</h2>

				{
					jour2.length > 0 ? (
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
							{jour2.map((artiste) => (
								<a
									href={`/artiste/${artiste.id}`}
									class="artiste-card bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform"
									data-jour="19"
									data-scene={artiste.scene || ""}
									data-genre={artiste.genre_musical || ""}
								>
									{artiste.photo_principale ? (
										<img
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
											alt={artiste.nom}
											class="w-full h-48 object-cover"
										/>
									) : (
										<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
											<span class="text-gris text-sm">
												Pas d'image
											</span>
										</div>
									)}
									<div class="p-4">
										<h3 class="text-white text-xl font-bold">
											{artiste.nom}
										</h3>
										<p class="text-violet">
											{formatHeure(
												artiste.date_representation,
											)}
										</p>
										<p class="text-gris text-sm">
											{artiste.genre_musical}
										</p>
									</div>
								</a>
							))}
						</div>
					) : (
						<p class="text-gris text-center">
							Programmation a venir...
						</p>
					)
				}
			</div>

			<!-- JOUR 3 -->
			<div class="mb-16" data-section-jour="20">
				<h2 class="text-white text-3xl font-bold mb-8 text-center">
					<span class="text-violet">Dimanche</span> 20 Juillet
				</h2>

				{
					jour3.length > 0 ? (
						<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
							{jour3.map((artiste) => (
								<a
									href={`/artiste/${artiste.id}`}
									class="artiste-card bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform"
									data-jour="20"
									data-scene={artiste.scene || ""}
									data-genre={artiste.genre_musical || ""}
								>
									{artiste.photo_principale ? (
										<img
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
											alt={artiste.nom}
											class="w-full h-48 object-cover"
										/>
									) : (
										<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
											<span class="text-gris text-sm">
												Pas d'image
											</span>
										</div>
									)}
									<div class="p-4">
										<h3 class="text-white text-xl font-bold">
											{artiste.nom}
										</h3>
										<p class="text-violet">
											{formatHeure(
												artiste.date_representation,
											)}
										</p>
										<p class="text-gris text-sm">
											{artiste.genre_musical}
										</p>
									</div>
								</a>
							))}
						</div>
					) : (
						<p class="text-gris text-center">
							Programmation a venir...
						</p>
					)
				}
			</div>
		</div>
	</section>

	<!-- CTA SCENES -->
	<section class="py-16 px-4 bg-dark-blue">
		<div class="max-w-4xl mx-auto text-center">
			<h2
				class="text-4xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent"
			>
				Découvrez nos scènes
			</h2>
			<p class="text-gris text-lg mb-8 max-w-2xl mx-auto">
				Trois univers sonores distincts pour une expérience immersive :
				Main Stage avec les plus grands noms de l'électro, Arena pour
				les sets intimistes et Sunrise pour vibrer jusqu'à l'aube.
			</p>
			<a
				href="/scene"
				class="inline-block bg-gradient-3c text-white px-8 py-3 rounded-full font-bold hover:opacity-80 transition-opacity"
			>
				Voir les scènes
			</a>
		</div>
	</section>

	<script>
		// === SYSTEME DE FILTRAGE ===
		let jourSelectionne = "tous";
		let sceneSelectionnee = "toutes";
		let genreSelectionne = "tous";

		function appliquerFiltres() {
			const cartes =
				document.querySelectorAll<HTMLElement>(".artiste-card");
			let nombreVisibles = 0;

			cartes.forEach((carte) => {
				const jour = carte.getAttribute("data-jour");
				const scene = carte.getAttribute("data-scene");
				const genre = carte.getAttribute("data-genre");

				const jourMatch =
					jourSelectionne === "tous" || jour === jourSelectionne;
				const sceneMatch =
					sceneSelectionnee === "toutes" ||
					scene === sceneSelectionnee;
				const genreMatch =
					genreSelectionne === "tous" || genre === genreSelectionne;

				if (jourMatch && sceneMatch && genreMatch) {
					carte.style.display = "";
					nombreVisibles++;
				} else {
					carte.style.display = "none";
				}
			});

			// Gérer l'affichage des sections de jours
			gererAffichageSections();
		}

		function gererAffichageSections() {
			["18", "19", "20"].forEach((jour) => {
				const section = document.querySelector<HTMLElement>(
					`[data-section-jour="${jour}"]`,
				);
				if (!section) return;

				const cartesVisibles = section.querySelectorAll(
					'.artiste-card:not([style*="display: none"])',
				);

				if (cartesVisibles.length === 0) {
					section.style.display = "none";
				} else {
					section.style.display = "";
				}
			});
		}

		document.querySelectorAll(".filter-btn-jour").forEach((btn) => {
			btn.addEventListener("click", () => {
				document.querySelectorAll(".filter-btn-jour").forEach((b) => {
					b.classList.remove("active", "bg-violet");
					b.classList.add("bg-violet-foncer");
				});
				btn.classList.add("active", "bg-violet");
				btn.classList.remove("bg-violet-foncer");

				jourSelectionne =
					btn.getAttribute("data-filter-jour") || "tous";
				appliquerFiltres();
			});
		});

		document.querySelectorAll(".filter-btn-scene").forEach((btn) => {
			btn.addEventListener("click", () => {
				document.querySelectorAll(".filter-btn-scene").forEach((b) => {
					b.classList.remove("active", "bg-violet");
					b.classList.add("bg-violet-foncer");
				});
				btn.classList.add("active", "bg-violet");
				btn.classList.remove("bg-violet-foncer");

				sceneSelectionnee =
					btn.getAttribute("data-filter-scene") || "toutes";
				appliquerFiltres();
			});
		});

		document.querySelectorAll(".filter-btn-genre").forEach((btn) => {
			btn.addEventListener("click", () => {
				document.querySelectorAll(".filter-btn-genre").forEach((b) => {
					b.classList.remove("active", "bg-violet");
					b.classList.add("bg-violet-foncer");
				});
				btn.classList.add("active", "bg-violet");
				btn.classList.remove("bg-violet-foncer");

				genreSelectionne =
					btn.getAttribute("data-filter-genre") || "tous";
				appliquerFiltres();
			});
		});
	</script>
</Layout>
