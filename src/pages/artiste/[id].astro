---
import Layout from '../../layouts/Layout.astro';
import { artisteID, sceneID } from '../../../backend/backend.mjs';
import type { RecordModel } from 'pocketbase';

// Recuperer l'ID depuis l'URL
const { id } = Astro.params;

// Variables pour stocker les donnees
let artiste: RecordModel | null = null;
let scene: RecordModel | null = null;
let error: string | null = null;

// Recuperer les donnees de l'artiste
try {
	artiste = await artisteID(id);
	
	// Recuperer les infos de la scene
	if (artiste && artiste.scene) {
		scene = await sceneID(artiste.scene);
	}
} catch (e) {
	error = "Artiste non trouve";
	console.error("Erreur:", e);
}

// Fonction pour formater la date
function formatDate(dateString: string) {
	const date = new Date(dateString);
	const options: Intl.DateTimeFormatOptions = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
	return date.toLocaleDateString('fr-FR', options);
}

// Fonction pour formater l'heure
function formatTime(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

// URL de base PocketBase pour les images
const pbUrl = "http://127.0.0.1:8090";
---

<Layout title={artiste ? `${artiste.nom} - Lumimix` : "Artiste - Lumimix"}>
	
	{error ? (
		<!-- MESSAGE D'ERREUR -->
		<section class="pt-32 pb-16 px-4 text-center min-h-screen">
			<h1 class="text-white text-4xl font-bold mb-4">Artiste non trouve</h1>
			<p class="text-gris mb-8">L'artiste que vous recherchez n'existe pas.</p>
			<a 
				href="/artiste" 
				class="inline-block bg-violet text-white px-8 py-3 rounded-full font-bold hover:opacity-80"
			>
				Voir tous les artistes
			</a>
		</section>
	) : artiste && (
		<!-- CONTENU DE LA PAGE -->
		<>
			<!-- HERO ARTISTE -->
			<section class="pt-32 pb-16 px-4">
				<div class="max-w-5xl mx-auto">
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
						
						<!-- Image principale -->
						<div class="relative">
							{artiste.photo_principale ? (
								<img 
									src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
									alt={artiste.nom} 
									class="w-full h-96 object-cover rounded-2xl"
								/>
							) : (
								<div class="w-full h-96 bg-violet-foncer rounded-2xl flex items-center justify-center">
									<span class="text-gris text-xl">Pas d'image</span>
								</div>
							)}
							<!-- Badge genre -->
					<span class="absolute top-4 left-4 px-4 py-2 rounded-full font-bold bg-gradient-3c text-white">
								{artiste.genre_musical}
							</span>
						</div>
						
						<!-- Infos artiste -->
						<div>
							<h1 class="text-5xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent">{artiste.nom}</h1>
							
							<!-- Infos pratiques -->
							<div class="space-y-4 mb-8">
								<div class="flex items-center gap-3">
									<span class="text-violet font-bold">Date :</span>
									<span class="text-white">{formatDate(artiste.date_representation)}</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-violet font-bold">Heure :</span>
									<span class="text-white">{formatTime(artiste.date_representation)}</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-violet font-bold">Scene :</span>
									<span class="text-white">{scene ? scene.nom : "Non definie"}</span>
								</div>
								<div class="flex items-center gap-3">
									<span class="text-violet font-bold">Genre :</span>
									<span class="text-white">{artiste.genre_musical}</span>
								</div>
							</div>
							
							<!-- Boutons -->
							<div class="flex flex-wrap gap-4">
								<a 
									href="/billetterie" 
									class="px-8 py-3 rounded-full font-bold hover:opacity-80 bg-gradient-3c text-white"
								>
									Reserver ma place
								</a>
								{scene && (
									<a 
										href="/scene"
										class="border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
									>
										Voir la scene
									</a>
								)}
							</div>
						</div>
						
					</div>
				</div>
			</section>

			<!-- DESCRIPTION -->
			{artiste.description && (
				<section class="pb-16 px-4">
					<div class="max-w-3xl mx-auto">
						<h2 class="text-3xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent">A propos</h2>
						<p class="text-gris text-lg leading-relaxed">
							{artiste.description}
						</p>
					</div>
				</section>
			)}

			<!-- GALERIE PHOTOS - CARROUSEL INFINI -->
			{artiste.galerie_photos && artiste.galerie_photos.length > 0 && (
				<section class="pb-16 px-4">
					<div class="max-w-7xl mx-auto">
						<h2 class="text-3xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent">Galerie</h2>
						<div class="relative overflow-hidden">
							<!-- Conteneur du carrousel -->
							<div id="carousel-track" class="flex gap-4 transition-transform duration-700 ease-in-out">
								{/* Images originales */}
								{artiste.galerie_photos.map((photo) => (
							<div class="shrink-0 w-64 md:w-80">
										<img 
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${photo}`}
											alt={`Photo de ${artiste.nom}`}
											class="w-full h-64 md:h-80 object-cover rounded-xl"
										/>
									</div>
								))}
								{/* Duplication pour l'effet infini */}
								{artiste.galerie_photos.map((photo) => (
							<div class="shrink-0 w-64 md:w-80">
										<img 
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${photo}`}
											alt={`Photo de ${artiste.nom}`}
											class="w-full h-64 md:h-80 object-cover rounded-xl"
										/>
									</div>
								))}
							</div>
							
							<!-- Boutons de navigation -->
							<button 
								id="prev-btn"
								class="absolute left-4 top-1/2 -translate-y-1/2 bg-violet/80 hover:bg-violet text-white w-12 h-12 rounded-full flex items-center justify-center z-10 transition-colors"
								aria-label="Photo précédente"
							>
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
									<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
								</svg>
							</button>
							<button 
								id="next-btn"
								class="absolute right-4 top-1/2 -translate-y-1/2 bg-violet/80 hover:bg-violet text-white w-12 h-12 rounded-full flex items-center justify-center z-10 transition-colors"
								aria-label="Photo suivante"
							>
								<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6">
									<path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
								</svg>
							</button>
						</div>
					</div>
				</section>
			)}

			<!-- BOUTON RETOUR -->
			<section class="pb-16 text-center">
				<a 
					href="/artiste" 
					class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
				>
					Voir tous les artistes
				</a>
			</section>
		</>
	)}

	<script>
		// Script pour le carrousel infini
		const track = document.getElementById('carousel-track');
		const prevBtn = document.getElementById('prev-btn');
		const nextBtn = document.getElementById('next-btn');
		
		if (track && prevBtn && nextBtn) {
			let currentIndex = 0;
			const items = track.querySelectorAll('.shrink-0');
			const totalItems = items.length / 2; // Divisé par 2 car on a dupliqué les images
			const itemWidth = (items[0] as HTMLElement)?.offsetWidth || 0;
			const gap = 16; // 4 * 4px (gap-4 en Tailwind)
			const slideWidth = itemWidth + gap;
			
			let autoScrollInterval;
			
			function updateCarousel(smooth = true) {
				if (!smooth) {
					track!.style.transition = 'none';
				} else {
					track!.style.transition = 'transform 0.7s ease-in-out';
				}
				track!.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
			}
			
			function nextSlide() {
				currentIndex++;
				updateCarousel();
				
				// Réinitialiser quand on atteint la fin des images originales
				if (currentIndex >= totalItems) {
					setTimeout(() => {
						currentIndex = 0;
						updateCarousel(false);
					}, 700);
				}
			}
			
			function prevSlide() {
				if (currentIndex === 0) {
					currentIndex = totalItems;
					updateCarousel(false);
					setTimeout(() => {
						currentIndex--;
						updateCarousel();
					}, 50);
				} else {
					currentIndex--;
					updateCarousel();
				}
			}
			
			// Auto-scroll
			function startAutoScroll() {
				autoScrollInterval = setInterval(nextSlide, 3000);
			}
			
			function stopAutoScroll() {
				clearInterval(autoScrollInterval);
			}
			
			// Event listeners pour les boutons
			nextBtn.addEventListener('click', () => {
				stopAutoScroll();
				nextSlide();
				startAutoScroll();
			});
			
			prevBtn.addEventListener('click', () => {
				stopAutoScroll();
				prevSlide();
				startAutoScroll();
			});
			
			// Pause au survol
			track.addEventListener('mouseenter', stopAutoScroll);
			track.addEventListener('mouseleave', startAutoScroll);
			
			// Démarrer l'auto-scroll
			startAutoScroll();
		}
	</script>

</Layout>
