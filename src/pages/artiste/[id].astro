---
import Layout from "../../layouts/Layout.astro";
import { artisteID } from "../../../backend/backend.mjs";
import type { RecordModel } from "pocketbase";

const { id } = Astro.params;

let artiste: RecordModel | null = null;
let error: string | null = null;

try {
	artiste = await artisteID(id);
} catch (e) {
	error = "Artiste non trouvé";
}

function formatDate(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleDateString("fr-FR", {
		weekday: "long",
		day: "numeric",
		month: "long",
		year: "numeric",
	});
}

function formatTime(dateString: string) {
	const date = new Date(dateString);
	return date.toLocaleTimeString("fr-FR", {
		hour: "2-digit",
		minute: "2-digit",
	});
}

const pbUrl = "http://127.0.0.1:8090";
const sceneName = artiste?.expand?.scene?.nom || "Non définie";
---

<Layout title={artiste ? `${artiste.nom} - Lumimix` : "Artiste - Lumimix"}>
	{
		error ? (
			<section class="pt-32 pb-16 px-4 text-center min-h-screen">
				<h1 class="text-white text-4xl font-bold mb-4">
					Artiste non trouvé
				</h1>
				<p class="text-gris mb-8">
					L'artiste que vous recherchez n'existe pas.
				</p>
				<a
					href="/artiste"
					class="inline-block bg-violet text-white px-8 py-3 rounded-full font-bold hover:opacity-80"
				>
					Voir tous les artistes
				</a>
			</section>
		) : (
			artiste && (
				<>
					<section class="pt-32 pb-16 px-4">
						<div class="max-w-5xl mx-auto">
							<div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
								<div class="relative">
									{artiste.photo_principale ? (
										<img
											src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
											alt={artiste.nom}
											class="w-full h-96 object-cover rounded-2xl"
										/>
									) : (
										<div class="w-full h-96 bg-violet-foncer rounded-2xl flex items-center justify-center">
											<span class="text-gris text-xl">
												Pas d'image
											</span>
										</div>
									)}
									<span class="absolute top-4 left-4 px-4 py-2 rounded-full font-bold bg-gradient-3c text-white">
										{artiste.genre_musical}
									</span>
								</div>

								<div>
									<h1 class="text-5xl font-bold mb-6 bg-gradient-3c bg-clip-text text-transparent">
										{artiste.nom}
									</h1>
									<div class="space-y-4 mb-8">
										<div class="flex items-center gap-3">
											<span class="text-violet font-bold">
												Date :
											</span>
											<span class="text-white capitalize">
												{formatDate(
													artiste.date_representation,
												)}
											</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-violet font-bold">
												Heure :
											</span>
											<span class="text-white">
												{formatTime(
													artiste.date_representation,
												)}
											</span>
										</div>
										<div class="flex items-center gap-3">
											<span class="text-violet font-bold">
												Scène :
											</span>
											<span class="text-white">
												{sceneName}
											</span>
										</div>
									</div>

									<div class="flex flex-wrap gap-4">
										<a
											href="/billetterie"
											class="px-8 py-3 rounded-full font-bold hover:opacity-80 bg-gradient-3c text-white"
										>
											Réserver ma place
										</a>
										{artiste.scene && (
											<a
												href={`/scene/${artiste.scene}`}
												class="border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white transition-colors"
											>
												Voir la scène
											</a>
										)}
									</div>
								</div>
							</div>
						</div>
					</section>

					{artiste.galerie_photos && artiste.galerie_photos.length > 0 && (
						<section class="pb-16 px-4">
							<div class="max-w-5xl mx-auto">
								<h2 class="text-3xl font-bold mb-8 text-white">
									Galerie photos
								</h2>
								<div class="relative overflow-hidden group">
									<button
										id="prev-galerie"
										class="absolute left-2 top-1/2 -translate-y-1/2 z-10 bg-violet/80 text-white p-3 rounded-full hover:bg-violet transition-all opacity-0 group-hover:opacity-100"
										aria-label="Photo précédente"
									>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
										</svg>
									</button>
									<button
										id="next-galerie"
										class="absolute right-2 top-1/2 -translate-y-1/2 z-10 bg-violet/80 text-white p-3 rounded-full hover:bg-violet transition-all opacity-0 group-hover:opacity-100"
										aria-label="Photo suivante"
									>
										<svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
										</svg>
									</button>
									<div
										id="carousel-galerie"
										class="flex transition-transform duration-500 ease-in-out"
									>
										{artiste.galerie_photos.map(
											(photo: string) => (
												<div class="min-w-full md:min-w-[33.333%] px-2">
													<img
														src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${photo}`}
														alt={`Photo de ${artiste.nom}`}
														class="w-full h-64 object-cover rounded-xl"
													/>
												</div>
											),
										)}
										{artiste.galerie_photos.map(
											(photo: string) => (
												<div class="min-w-full md:min-w-[33.333%] px-2">
													<img
														src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${photo}`}
														alt={`Photo de ${artiste.nom}`}
														class="w-full h-64 object-cover rounded-xl"
													/>
												</div>
											),
										)}
									</div>
								</div>
							</div>
						</section>
					)}

					<script>
						const carousel = document.getElementById('carousel-galerie');
						const prevBtn = document.getElementById('prev-galerie');
						const nextBtn = document.getElementById('next-galerie');
						
						if (carousel && prevBtn && nextBtn) {
							const totalItems = carousel.children.length / 2;
							const itemsPerSlide = window.innerWidth >= 768 ? 3 : 1;
							let currentIndex = 0;
							
							function updateCarousel() {
								const itemWidth = 100 / itemsPerSlide;
								const offset = -(itemWidth * currentIndex);
								carousel!.style.transform = `translateX(${offset}%)`;
							}
							
							nextBtn.addEventListener('click', () => {
								currentIndex++;
								updateCarousel();
								
								if (currentIndex >= totalItems) {
									setTimeout(() => {
										carousel!.style.transition = 'none';
										currentIndex = 0;
										updateCarousel();
										setTimeout(() => {
											carousel!.style.transition = 'transform 500ms ease-in-out';
										}, 20);
									}, 500);
								}
							});
							
							prevBtn.addEventListener('click', () => {
								if (currentIndex === 0) {
									carousel!.style.transition = 'none';
									currentIndex = totalItems;
									updateCarousel();
									setTimeout(() => {
										carousel!.style.transition = 'transform 500ms ease-in-out';
										currentIndex--;
										updateCarousel();
									}, 20);
								} else {
									currentIndex--;
									updateCarousel();
								}
							});
						}
					</script>
				</>
			)
		)
	}
</Layout>
