---
import Layout from '../../layouts/Layout.astro';

// Images des artistes
import djRouge from '../../assets/img/dj_rouge.avif';
import djBleu from '../../assets/img/dj_bleu.avif';
import djFlamme from '../../assets/img/dj_flamme.avif';
import djNoirBlanc from '../../assets/img/dj_noir_blanc.avif';
import djCacher from '../../assets/img/dj_cacher.avif';
import djDeDos from '../../assets/img/dj_de_dos.avif';
import djRouge2 from '../../assets/img/dj_rouge_2.avif';
import djBleu2 from '../../assets/img/dj_bleu_2.avif';

// Liste des artistes (donnees simples)
const artistes = [
	{
		nom: "Charlotte de Witte",
		genre: "Techno",
		image: djRouge.src,
		jour: "Vendredi 18 Juillet",
		scene: "Main Stage",
		horaire: "23:00 - 01:00"
	},
	{
		nom: "Ben Bohmer",
		genre: "Melodic House",
		image: djBleu.src,
		jour: "Vendredi 18 Juillet",
		scene: "Reflets Stage",
		horaire: "21:00 - 23:00"
	},
	{
		nom: "Anfisa Letyago",
		genre: "Techno",
		image: djFlamme.src,
		jour: "Vendredi 18 Juillet",
		scene: "Drones Stage",
		horaire: "01:00 - 03:00"
	},
	{
		nom: "Boris Brejcha",
		genre: "High-Tech Minimal",
		image: djNoirBlanc.src,
		jour: "Samedi 19 Juillet",
		scene: "Main Stage",
		horaire: "23:00 - 01:00"
	},
	{
		nom: "Nina Kraviz",
		genre: "Techno",
		image: djCacher.src,
		jour: "Samedi 19 Juillet",
		scene: "Reflets Stage",
		horaire: "21:00 - 23:00"
	},
	{
		nom: "Amelie Lens",
		genre: "Techno",
		image: djDeDos.src,
		jour: "Samedi 19 Juillet",
		scene: "Drones Stage",
		horaire: "01:00 - 03:00"
	},
	{
		nom: "Tale Of Us",
		genre: "Melodic Techno",
		image: djRouge2.src,
		jour: "Dimanche 20 Juillet",
		scene: "Main Stage",
		horaire: "22:00 - 00:00"
	},
	{
		nom: "Peggy Gou",
		genre: "House",
		image: djBleu2.src,
		jour: "Dimanche 20 Juillet",
		scene: "Reflets Stage",
		horaire: "20:00 - 22:00"
	}
];
---

<Layout title="Artistes - Lumimix">
	
	<!-- HEADER DE PAGE -->
	<section class="pt-32 pb-16 px-4 text-center">
		<h1 class="text-white text-5xl font-bold mb-4">Artistes</h1>
		<p class="text-gris text-lg max-w-2xl mx-auto">
			Les plus grands DJs de la scene electronique internationale
		</p>
	</section>

	<!-- GRILLE DES ARTISTES -->
	<section class="pb-16 px-4">
		<div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
			
			{artistes.map((artiste) => (
				<!-- CARTE ARTISTE -->
				<div class="bg-violet-foncer/30 rounded-2xl overflow-hidden">
					
					<!-- Image -->
					<div class="relative">
						<img 
							src={artiste.image} 
							alt={artiste.nom} 
							class="w-full h-48 object-cover"
						/>
						<!-- Badge genre -->
						<span class="absolute top-3 left-3 bg-violet text-white text-xs px-3 py-1 rounded-full">
							{artiste.genre}
						</span>
					</div>
					
					<!-- Infos -->
					<div class="p-4">
						<h3 class="text-white text-xl font-bold mb-2">{artiste.nom}</h3>
						<p class="text-gris text-sm mb-1">{artiste.jour}</p>
						<p class="text-violet text-sm font-medium">{artiste.scene}</p>
						<p class="text-gris text-sm">{artiste.horaire}</p>
					</div>
					
				</div>
			))}

		</div>
	</section>

	<!-- BOUTON RETOUR -->
	<section class="pb-16 text-center">
		<a 
			href="/" 
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
		>
			Retour a l'accueil
		</a>
	</section>

</Layout>
