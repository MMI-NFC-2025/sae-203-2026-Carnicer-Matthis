---
import Layout from '../../layouts/Layout.astro';
import { artistesSorted, scenesName } from '../../../backend/backend.mjs';

// Recuperer les artistes depuis PocketBase
let artistes = [];
let scenes = [];

try {
	artistes = await artistesSorted();
	scenes = await scenesName();
} catch (error) {
	console.error("Erreur lors de la recuperation des donnees:", error);
}

// Fonction pour obtenir le nom de la scene
function getSceneName(sceneId) {
	const scene = scenes.find(s => s.id === sceneId);
	return scene ? scene.nom : "Scene inconnue";
}

// Fonction pour formater la date
function formatDate(dateString) {
	const date = new Date(dateString);
	const options = { weekday: 'long', day: 'numeric', month: 'long' };
	return date.toLocaleDateString('fr-FR', options);
}

// Fonction pour formater l'heure
function formatTime(dateString) {
	const date = new Date(dateString);
	return date.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
}

// URL de base PocketBase pour les images
const pbUrl = "http://127.0.0.1:8090";
---

<Layout title="Artistes - Lumimix">
	
	<!-- HEADER DE PAGE -->
	<section class="pt-32 pb-16 px-4 text-center">
		<h1 class="text-white text-5xl font-bold mb-4">Artistes</h1>
		<p class="text-gris text-lg max-w-2xl mx-auto">
			Les plus grands DJs de la scene electronique internationale
		</p>
	</section>

	<!-- GRILLE DES ARTISTES -->
	<section class="pb-16 px-4">
		<div class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
			
			{artistes.map((artiste) => (
				<!-- CARTE ARTISTE (cliquable) -->
				<a href={`/artiste/${artiste.id}`} class="bg-violet-foncer/30 rounded-2xl overflow-hidden hover:scale-105 transition-transform block">
					
					<!-- Image -->
					<div class="relative">
						{artiste.photo_principale ? (
							<img 
								src={`${pbUrl}/api/files/${artiste.collectionId}/${artiste.id}/${artiste.photo_principale}`}
								alt={artiste.nom} 
								class="w-full h-48 object-cover"
							/>
						) : (
							<div class="w-full h-48 bg-violet-foncer flex items-center justify-center">
								<span class="text-gris">Pas d'image</span>
							</div>
						)}
						<!-- Badge genre -->
						<span class="absolute top-3 left-3 bg-violet text-white text-xs px-3 py-1 rounded-full">
							{artiste.genre_musical}
						</span>
					</div>
					
					<!-- Infos -->
					<div class="p-4">
						<h3 class="text-white text-xl font-bold mb-2">{artiste.nom}</h3>
						<p class="text-gris text-sm mb-1">{formatDate(artiste.date_representation)}</p>
						<p class="text-violet text-sm font-medium">{getSceneName(artiste.scene)}</p>
						<p class="text-gris text-sm">{formatTime(artiste.date_representation)}</p>
					</div>
					
				</a>
			))}

		</div>
	</section>

	<!-- MESSAGE SI PAS D'ARTISTES -->
	{artistes.length === 0 && (
		<section class="pb-16 text-center">
			<p class="text-gris text-lg">Aucun artiste trouve. Verifiez que PocketBase est lance.</p>
		</section>
	)}

	<!-- BOUTON RETOUR -->
	<section class="pb-16 text-center">
		<a 
			href="/" 
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white"
		>
			Retour a l'accueil
		</a>
	</section>

</Layout>
