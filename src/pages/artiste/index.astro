---
import Layout from "../../layouts/Layout.astro";
import CardArtiste from "../../components/CardArtiste.astro";
import {
	artistesSorted,
	artistesName,
	scenesName,
} from "../../../backend/backend.mjs";
import type { RecordModel } from "pocketbase";
import djFondImage from "../../assets/img/dj_fond.avif";

let artistes: RecordModel[] = [];
let artistesAlpha: RecordModel[] = [];
let scenes: RecordModel[] = [];
try {
	artistes = await artistesSorted();
	artistesAlpha = await artistesName();
	scenes = await scenesName();
} catch (error) {
	console.error("Erreur:", error);
}
---

<Layout title="Artistes - Lumimix">
	<section
		class="relative h-[70vh] flex items-start justify-center px-4 text-center pt-40"
	>
		<img
			src={djFondImage.src}
			alt="DJ Background"
			class="absolute inset-0 w-full h-full object-cover z-0"
		/>
		<div class="absolute inset-0 bg-black/50 z-10"></div>
		<div class="relative z-20">
			<h1
				class="text-5xl font-bold mb-4 bg-gradient-3c bg-clip-text text-transparent"
			>
				Artistes
			</h1>
			<p class="text-white text-lg max-w-2xl mx-auto">
				Les plus grands DJs de la scène électronique internationale
			</p>
		</div>
	</section>

	<!-- FILTRES DE TRI -->
	<section class="py-8 px-4 border-b border-violet/20">
		<div class="max-w-6xl mx-auto">
			<h2 class="text-white font-bold text-xl mb-4">Trier par :</h2>
			<div class="flex flex-wrap gap-2">
				<button
					id="tri-date"
					class="filter-btn active px-6 py-2 rounded-full bg-violet text-white font-bold hover:opacity-80 transition-opacity"
				>
					Par date de concert
				</button>
				<button
					id="tri-alpha"
					class="filter-btn px-6 py-2 rounded-full bg-violet-foncer text-white font-bold hover:bg-violet transition-colors"
				>
					Par ordre alphabétique
				</button>
			</div>
		</div>
	</section>

	<section class="pt-16 pb-16 px-4">
		<div
			id="grille-artistes-date"
			class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
		>
			{
				artistes.map((artiste) => (
					<CardArtiste artiste={artiste} scenes={scenes} />
				))
			}
		</div>
		<div
			id="grille-artistes-alpha"
			class="max-w-6xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6"
			style="display: none;"
		>
			{
				artistesAlpha.map((artiste) => (
					<CardArtiste artiste={artiste} scenes={scenes} />
				))
			}
		</div>
	</section>

	{
		artistes.length === 0 && (
			<section class="pb-16 text-center">
				<p class="text-gris text-lg">
					Aucun artiste trouvé. Vérifiez que PocketBase est lancé.
				</p>
			</section>
		)
	}

	<section class="pb-16 text-center">
		<a
			href="/"
			class="inline-block border-2 border-violet text-violet px-8 py-3 rounded-full font-bold hover:bg-violet hover:text-white transition-colors"
		>
			Retour à l'accueil
		</a>
	</section>

	<script>
		// === SYSTEME DE TRI ===
		const btnTriDate = document.getElementById("tri-date");
		const btnTriAlpha = document.getElementById("tri-alpha");
		const grilleDate = document.getElementById(
			"grille-artistes-date",
		) as HTMLElement;
		const grilleAlpha = document.getElementById(
			"grille-artistes-alpha",
		) as HTMLElement;

		function activerTri(
			btnActif: HTMLElement,
			btnInactif: HTMLElement,
			grilleVisible: HTMLElement,
			grilleCachee: HTMLElement,
		) {
			btnActif.classList.add("active", "bg-violet");
			btnActif.classList.remove("bg-violet-foncer");
			btnInactif.classList.remove("active", "bg-violet");
			btnInactif.classList.add("bg-violet-foncer");
			grilleVisible.style.display = "grid";
			grilleCachee.style.display = "none";
		}

		btnTriDate?.addEventListener("click", () => {
			if (btnTriDate && btnTriAlpha && grilleDate && grilleAlpha) {
				activerTri(btnTriDate, btnTriAlpha, grilleDate, grilleAlpha);
			}
		});

		btnTriAlpha?.addEventListener("click", () => {
			if (btnTriDate && btnTriAlpha && grilleDate && grilleAlpha) {
				activerTri(btnTriAlpha, btnTriDate, grilleAlpha, grilleDate);
			}
		});
	</script>
</Layout>
